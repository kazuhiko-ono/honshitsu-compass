---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(130 178 164);
    --aw-color-secondary: rgb(110 156 143);
    --aw-color-accent: rgb(168 210 198);

    --aw-color-text-heading: rgb(80 96 90);
    --aw-color-text-default: rgb(115 107 100);
    --aw-color-text-muted: rgb(162 150 138);
    --aw-color-bg-page: rgb(250 248 245);

    --aw-color-bg-page-dark: rgb(230 238 234);

    --color-bg-primary: #faf8f5;
    --color-bg-secondary: #f2f7f4;
    --color-bg-dark: #e6eeea;
    --color-text-primary: #50605a;
    --color-text-body: #736b64;
    --color-text-muted: #a2968a;
    --color-text-on-dark: #e8f2ee;
    --color-accent: #82b2a4;
    --color-accent-light: #a8d2c6;
    --color-border: #e8e2da;
    --color-border-dark: rgba(255,255,255,0.12);

    ::selection {
      background-color: #deeee6;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(110 158 144);
    --aw-color-secondary: rgb(90 138 124);
    --aw-color-accent: rgb(150 196 182);

    --aw-color-text-heading: rgb(60 75 68);
    --aw-color-text-default: rgb(80 95 88);
    --aw-color-text-muted: rgb(130 148 140);
    --aw-color-bg-page: rgb(230 238 234);

    ::selection {
      background-color: rgb(190 218 208);
      color: rgb(60 75 68);
    }
  }
</style>
