---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(74 124 111);
    --aw-color-secondary: rgb(60 102 91);
    --aw-color-accent: rgb(122 184 168);

    --aw-color-text-heading: rgb(44 58 53);
    --aw-color-text-default: rgb(90 80 72);
    --aw-color-text-muted: rgb(138 122 106);
    --aw-color-bg-page: rgb(245 242 237);

    --aw-color-bg-page-dark: rgb(44 58 53);

    --color-bg-primary: #f5f2ed;
    --color-bg-secondary: #eef4f0;
    --color-bg-dark: #2c3a35;
    --color-text-primary: #2c3a35;
    --color-text-body: #5a5048;
    --color-text-muted: #8a7a6a;
    --color-text-on-dark: #e8f2ee;
    --color-accent: #4a7c6f;
    --color-accent-light: #7ab8a8;
    --color-border: #e0d8ce;
    --color-border-dark: rgba(255,255,255,0.15);

    ::selection {
      background-color: #d4e8df;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(122 184 168);
    --aw-color-secondary: rgb(74 124 111);
    --aw-color-accent: rgb(122 184 168);

    --aw-color-text-heading: rgb(232 242 238);
    --aw-color-text-default: rgb(232 242 238);
    --aw-color-text-muted: rgb(232 242 238 / 66%);
    --aw-color-bg-page: rgb(44 58 53);

    ::selection {
      background-color: rgb(74 124 111);
      color: snow;
    }
  }
</style>
